{
  "expo": {
    "name": "Tenis-Lab",
    "slug": "TennisAppV1",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/canchero-logo.png",
    "scheme": "tennisappv1",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gusgvarg.tennisappv1",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Tenis-Lab to access your camera to record video analysis.",
        "NSMicrophoneUsageDescription": "Allow Tenis-Lab to access your microphone to record audio during analysis."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1E293B",
        "foregroundImage": "./assets/images/canchero-logo.png"
      },
      "package": "com.gusgvarg.tennisappv1",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/canchero-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1E293B",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Tenis-Lab to access your camera to record video analysis.",
          "microphonePermission": "Allow Tenis-Lab to access your microphone to record audio during analysis."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f65bd316-8774-43f7-8d86-b3557ca90338"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f65bd316-8774-43f7-8d86-b3557ca90338"
    }
  }
}